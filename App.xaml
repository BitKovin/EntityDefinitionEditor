<Application x:Class="EntityEditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EntityEditor.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <conv:InverseBoolConverter             x:Key="InvBool"/>
            <conv:BoolToVisibilityConverter    x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
            <conv:RgbToColorConverter          x:Key="RgbToColor"/>
            <conv:BoolToItalicConverter        x:Key="BoolToItalic"/>
            <conv:BoolToOpacityConverter       x:Key="BoolToOpacity"/>
            <conv:IsFlagTypeConverter          x:Key="IsFlagType"/>
            <conv:NotNullOrEmptyConverter      x:Key="NotNullOrEmpty"/>
            <conv:DoubleToStringConverter      x:Key="DoubleToStr"/>
            <conv:InheritedRowBrushConverter   x:Key="InheritedRowBrush"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
