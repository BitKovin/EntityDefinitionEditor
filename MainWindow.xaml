<Window x:Class="EntityEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EntityEditor.ViewModels"
        xmlns:models="clr-namespace:EntityEditor.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="{Binding WindowTitle}" Height="780" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ObjectDataProvider x:Key="PropertyTypeValues"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:PropertyType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveAsProjectCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenProjectCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- ═══ Menu Bar ═══════════════════════════════════════════════════ -->
        <Menu DockPanel.Dock="Top" Background="#FF2D2D30" Foreground="{StaticResource TextBrush}">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project"    Command="{Binding NewProjectCommand}"  InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open Project…"  Command="{Binding OpenProjectCommand}" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save"           Command="{Binding SaveProjectCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As…"       Command="{Binding SaveAsProjectCommand}" InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="_Import .ent…"   Command="{Binding ImportEntCommand}"/>
                <MenuItem Header="_Export to .ent…" Command="{Binding ExportEntCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="{Binding UndoLabel}" Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="{Binding RedoLabel}" Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y"/>
            </MenuItem>
            <MenuItem Header="_Entity">
                <MenuItem Header="Add Entity"       Command="{Binding AddEntityCommand}"/>
                <MenuItem Header="Duplicate Entity" Command="{Binding DuplicateEntityCommand}"/>
                <MenuItem Header="Delete Entity"    Command="{Binding DeleteEntityCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ═══ Status Bar ════════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom" Height="22">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock FontSize="11" Foreground="White">
                    <Run Text="{Binding Entities.Count, Mode=OneWay}"/>
                    <Run Text=" entities"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ Main Content ══════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="160" MaxWidth="380"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── Left: Entity List ─────────────────────────────────── -->
            <DockPanel Grid.Column="0" Background="{StaticResource PanelBrush}">

                <!-- Search -->
                <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0 0 0 1" Padding="6">
                    <Grid>
                        <TextBox x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="22 3 4 3" Background="#FF3C3C3C"
                                 ToolTip="Search entities by name"/>
                        <TextBlock Text="🔍" Foreground="{StaticResource DimTextBrush}"
                                   VerticalAlignment="Center" Margin="6 0 0 0"
                                   IsHitTestVisible="False" FontSize="11"/>
                        <TextBlock Text="Search…" Foreground="{StaticResource DimTextBrush}"
                                   VerticalAlignment="Center" Margin="24 0 0 0"
                                   IsHitTestVisible="False" FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Toolbar -->
                <Border DockPanel.Dock="Bottom"
                        Background="#FF1E1E1E"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0 1 0 0"
                        Height="32">
                    <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource IconButton}" Content="+" ToolTip="Add Entity"
                            Command="{Binding AddEntityCommand}" FontSize="14" Padding="6 2" Margin="2"/>
                    <Button Style="{StaticResource IconButton}" Content="⧉" ToolTip="Duplicate Entity"
                            Command="{Binding DuplicateEntityCommand}" Margin="2"/>
                    <Button Style="{StaticResource IconButton}" Content="✕" ToolTip="Delete Entity"
                            Command="{Binding DeleteEntityCommand}" Foreground="#FFFF6B6B" Margin="2"/>
                    <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="4 4"/>
                    <Button Style="{StaticResource IconButton}" Content="↑" ToolTip="Move Up"
                            Command="{Binding MoveEntityUpCommand}" Margin="2"/>
                    <Button Style="{StaticResource IconButton}" Content="↓" ToolTip="Move Down"
                            Command="{Binding MoveEntityDownCommand}" Margin="2"/>
                    </StackPanel>
                </Border>

                <!-- Entity List -->
                <ListBox x:Name="EntityList"
                         ItemsSource="{Binding FilteredEntities}"
                         SelectedItem="{Binding SelectedEntity}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Color swatch -->
                                <Rectangle Grid.Column="0" Width="8" Height="8"
                                           VerticalAlignment="Center" Margin="0 0 6 0"
                                           RadiusX="1" RadiusY="1">
                                    <Rectangle.Fill>
                                        <MultiBinding Converter="{StaticResource RgbToColor}">
                                            <Binding Path="ColorR"/>
                                            <Binding Path="ColorG"/>
                                            <Binding Path="ColorB"/>
                                        </MultiBinding>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <!-- Name -->
                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           FontFamily="Consolas" FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- Type badge -->
                                <Border Grid.Column="2" CornerRadius="2" Padding="3 0"
                                        Margin="4 0 0 0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FF3F3F46"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EntityType}" Value="group">
                                                    <Setter Property="Background" Value="#FF1E4D2B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntityType}" Value="abstract">
                                                    <Setter Property="Background" Value="#FF4D3B1E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding EntityType}" FontSize="9"
                                               Foreground="{StaticResource DimTextBrush}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- ─── Right: Entity Detail ───────────────────────────────── -->
            <Grid Grid.Column="2">
                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedEntity}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="No entity selected" Foreground="{StaticResource DimTextBrush}"
                               FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select or create an entity on the left" Margin="0 8"
                               Foreground="{StaticResource DimTextBrush}" HorizontalAlignment="Center"/>
                    <Button Content="+ Add Entity" Style="{StaticResource AccentButton}"
                            HorizontalAlignment="Center" Margin="0 8"
                            Command="{Binding AddEntityCommand}"/>
                </StackPanel>

                <!-- Detail panels (visible when entity selected) -->
                <Grid DataContext="{Binding SelectedEntity}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.SelectedEntity,
                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                             Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" MinHeight="0"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ── Top: Entity info panel ── -->
                    <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0 0 0 1"
                            Padding="12 10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left sub-column: Name, Type, Description -->
                            <StackPanel Grid.Column="0">
                                <Label Content="ENTITY NAME"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Consolas" FontSize="13" Margin="0 0 0 8"/>

                                <Label Content="TYPE"/>
                                <ComboBox ItemsSource="{Binding DataContext.EntityTypeOptions,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding EntityType}" Margin="0 0 0 8"/>

                                <Label Content="DESCRIPTION"/>
                                <TextBox Text="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         Height="54" VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>

                            <!-- Right sub-column: Color, Box, Inherits -->
                            <StackPanel Grid.Column="2">
                                <!-- Color -->
                                <Label Content="DISPLAY COLOR (R  G  B  0–1)"/>
                                <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                    <Border Width="28" Height="28" CornerRadius="4"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            Margin="0 0 6 0">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource RgbToColor}">
                                                <Binding Path="ColorR"/>
                                                <Binding Path="ColorG"/>
                                                <Binding Path="ColorB"/>
                                            </MultiBinding>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Width="54" Text="{Binding ColorR, Converter={StaticResource DoubleToStr}, UpdateSourceTrigger=LostFocus}" Margin="0 0 4 0"/>
                                    <TextBox Width="54" Text="{Binding ColorG, Converter={StaticResource DoubleToStr}, UpdateSourceTrigger=LostFocus}" Margin="0 0 4 0"/>
                                    <TextBox Width="54" Text="{Binding ColorB, Converter={StaticResource DoubleToStr}, UpdateSourceTrigger=LostFocus}"/>
                                </StackPanel>

                                <!-- Box -->
                                <Label Content="BOUNDING BOX (MIN / MAX)"/>
                                <StackPanel Margin="0 0 0 8">
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 2">
                                        <TextBlock Text="Min " Width="22" VerticalAlignment="Center"
                                                   Foreground="{StaticResource DimTextBrush}" FontSize="10"/>
                                        <TextBox Width="46" Text="{Binding BoxMinX, Converter={StaticResource DoubleToStr}, UpdateSourceTrigger=LostFocus}" Margin="0 0 2 0" ToolTip="Min X"/>
                                        <TextBox Width="46" Text="{Binding BoxMinY, Converter={StaticResource DoubleToStr}, UpdateSourceTrigger=LostFocus}" Margin="0 0 2 0" ToolTip="Min Y"/>
                                        <TextBox Width="46" Text="{Binding BoxMinZ, Converter={StaticResource DoubleToStr}, UpdateSourceTrigger=LostFocus}" ToolTip="Min Z"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Max " Width="22" VerticalAlignment="Center"
                                                   Foreground="{StaticResource DimTextBrush}" FontSize="10"/>
                                        <TextBox Width="46" Text="{Binding BoxMaxX, Converter={StaticResource DoubleToStr}, UpdateSourceTrigger=LostFocus}" Margin="0 0 2 0" ToolTip="Max X"/>
                                        <TextBox Width="46" Text="{Binding BoxMaxY, Converter={StaticResource DoubleToStr}, UpdateSourceTrigger=LostFocus}" Margin="0 0 2 0" ToolTip="Max Y"/>
                                        <TextBox Width="46" Text="{Binding BoxMaxZ, Converter={StaticResource DoubleToStr}, UpdateSourceTrigger=LostFocus}" ToolTip="Max Z"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Inherits -->
                                <Label Content="INHERITS FROM"/>
                                <WrapPanel Margin="0 0 0 4">
                                    <ItemsControl ItemsSource="{Binding Inherits}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FF2D4A2D" CornerRadius="3"
                                                        Padding="5 2" Margin="0 0 4 4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding}" FontSize="11"
                                                                   Foreground="{StaticResource GreenBrush}"/>
                                                        <Button Content="✕" FontSize="9" Padding="3 0"
                                                                Margin="4 0 0 0" Background="Transparent"
                                                                Foreground="{StaticResource DimTextBrush}"
                                                                Command="{Binding DataContext.RemoveInheritCommand,
                                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Content="+ Inherit" FontSize="10" Padding="5 2"
                                            Background="Transparent"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            Foreground="{StaticResource DimTextBrush}"
                                            Command="{Binding DataContext.AddInheritCommand,
                                                     RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Bottom: Properties ── -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="280" MinWidth="220" MaxWidth="420"/>
                        </Grid.ColumnDefinitions>

                        <!-- Properties list -->
                        <DockPanel Grid.Column="0">
                            <!-- Toolbar -->
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0 0 0 1"
                                    Background="#FF1E1E1E" Padding="6 4">
                                <DockPanel>
                                    <TextBlock Text="PROPERTIES" VerticalAlignment="Center"
                                               Style="{StaticResource SectionHeader}"
                                               Foreground="{StaticResource DimTextBrush}"/>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <!-- Built-in picker -->
                                        <ComboBox x:Name="BuiltInCombo" Width="140"
                                                  Padding="4 2" FontSize="11"
                                                  ItemsSource="{Binding DataContext.BuiltInProperties,
                                                               RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="Key"
                                                  ToolTip="Add a built-in property"/>
                                        <Button Content="Add Built-in" Margin="4 0 0 0" Padding="6 3" FontSize="11"
                                                Command="{Binding DataContext.AddBuiltInCommand,
                                                         RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding SelectedItem.Key, ElementName=BuiltInCombo}"/>
                                        <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="6 2"/>
                                        <Button Content="+ Property" Padding="6 3" FontSize="11"
                                                Style="{StaticResource AccentButton}"
                                                Command="{Binding DataContext.AddPropertyCommand,
                                                         RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <Button Content="✕ Delete" Padding="6 3" FontSize="11" Margin="4 0 0 0"
                                                Style="{StaticResource DangerButton}"
                                                Command="{Binding DataContext.DeletePropertyCommand,
                                                         RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- DataGrid -->
                            <DataGrid x:Name="PropertiesGrid"
                                      ItemsSource="{Binding AllProperties}"
                                      SelectedItem="{Binding SelectedProperty}"
                                      SelectionChanged="PropertiesGrid_SelectionChanged"
                                      BorderThickness="0">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                        <Setter Property="Background" Value="{Binding IsInherited, Converter={StaticResource InheritedRowBrush}}"/>
                                        <Setter Property="FontStyle"  Value="{Binding IsInherited, Converter={StaticResource BoolToItalic}}"/>
                                        <Setter Property="Opacity"    Value="{Binding IsInherited, Converter={StaticResource BoolToOpacity}}"/>
                                        <Setter Property="ToolTip"    Value="{Binding Description}"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <!-- Key -->
                                    <DataGridTextColumn Header="Key" Width="130"
                                                        Binding="{Binding Key, UpdateSourceTrigger=LostFocus}"
                                                        FontFamily="Consolas" FontSize="12">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="Padding"    Value="4 2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <!-- Display Name -->
                                    <DataGridTextColumn Header="Display Name" Width="150"
                                                        Binding="{Binding DisplayName, UpdateSourceTrigger=LostFocus}"/>
                                    <!-- Type -->
                                    <DataGridTemplateColumn Header="Type" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Type}" Padding="4 2"
                                                           Foreground="{StaticResource TextBrush}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                                          ItemsSource="{Binding Source={StaticResource PropertyTypeValues}}"
                                                          BorderThickness="0" Padding="2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <!-- Default Value -->
                                    <DataGridTextColumn Header="Default Value" Width="120"
                                                        Binding="{Binding DefaultValue, UpdateSourceTrigger=LostFocus}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource OrangeBrush}"/>
                                                <Setter Property="Padding"    Value="4 2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <!-- Source -->
                                    <DataGridTemplateColumn Header="Source" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="4 0">
                                                    <TextBlock Visibility="{Binding IsInherited, Converter={StaticResource BoolToVis}}"
                                                               Foreground="{StaticResource DimTextBrush}" FontSize="10">
                                                        <Run Text="↑ "/>
                                                        <Run Text="{Binding InheritedFrom}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="built-in" Foreground="#FF569CD6" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsBuiltIn}" Value="True"/>
                                                                            <Condition Binding="{Binding IsInherited}" Value="False"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>

                        <!-- Vertical splitter -->
                        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                      Background="{StaticResource BorderBrush}"/>

                        <!-- Property detail panel -->
                        <DockPanel Grid.Column="2" Background="{StaticResource PanelBrush}"
                                   DataContext="{Binding SelectedProperty}">
                            <!-- Header -->
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0 0 0 1"
                                    Background="#FF1E1E1E" Padding="8 5">
                                <TextBlock Text="PROPERTY DETAIL" Style="{StaticResource SectionHeader}"
                                           Foreground="{StaticResource DimTextBrush}"/>
                            </Border>

                            <!-- No property selected -->
                            <TextBlock DockPanel.Dock="Top" Text="Select a property to edit"
                                       Foreground="{StaticResource DimTextBrush}"
                                       HorizontalAlignment="Center" Margin="0 24">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Property fields -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <StackPanel>

                                    <!-- Inherited badge -->
                                    <Border Background="#FF2D3545" CornerRadius="4" Padding="8 4"
                                            Margin="0 0 0 10"
                                            Visibility="{Binding IsInherited, Converter={StaticResource BoolToVis}}">
                                        <TextBlock FontSize="11" TextWrapping="Wrap">
                                            <Run Text="↑ Inherited from "/>
                                            <Run Text="{Binding InheritedFrom}" Foreground="{StaticResource GreenBrush}"/>
                                            <LineBreak/>
                                            <Run Text="Add a property with the same key to override."
                                                 Foreground="{StaticResource DimTextBrush}" FontSize="10"/>
                                        </TextBlock>
                                    </Border>

                                    <!-- Built-in badge -->
                                    <Border Background="#FF1E2D45" CornerRadius="4" Padding="8 4"
                                            Margin="0 0 0 10"
                                            Visibility="{Binding IsBuiltIn, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="⬡ Built-in property" FontSize="11"
                                                   Foreground="#FF569CD6"/>
                                    </Border>

                                    <!-- Key -->
                                    <Label Content="KEY"/>
                                    <TextBox Text="{Binding Key, UpdateSourceTrigger=LostFocus}"
                                             FontFamily="Consolas" Foreground="{StaticResource GreenBrush}"
                                             IsReadOnly="{Binding IsInherited}"
                                             Margin="0 0 0 8"/>

                                    <!-- Display Name -->
                                    <Label Content="DISPLAY NAME"/>
                                    <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=LostFocus}"
                                             IsReadOnly="{Binding IsInherited}"
                                             Margin="0 0 0 8"/>

                                    <!-- Type -->
                                    <Label Content="TYPE"/>
                                    <ComboBox ItemsSource="{Binding Source={StaticResource PropertyTypeValues}}"
                                              SelectedItem="{Binding Type}"
                                              Margin="0 0 0 8">
                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInherited}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>
                                    </ComboBox>

                                    <!-- Type hint -->
                                    <Border Background="#FF1A1A2E" CornerRadius="3" Padding="6 4"
                                            Margin="0 0 0 10">
                                        <TextBlock x:Name="TypeHintBlock" FontSize="10" TextWrapping="Wrap"
                                                   Foreground="{StaticResource DimTextBrush}"/>
                                    </Border>

                                    <!-- Default Value -->
                                    <Label Content="DEFAULT VALUE"/>
                                    <TextBox Text="{Binding DefaultValue, UpdateSourceTrigger=LostFocus}"
                                             FontFamily="Consolas" Foreground="{StaticResource OrangeBrush}"
                                             IsReadOnly="{Binding IsInherited}"
                                             Margin="0 0 0 8"/>

                                    <!-- Bit Index (Flag only) -->
                                    <Label Content="BIT INDEX (SPAWNFLAG)"
                                           Visibility="{Binding Type, Converter={StaticResource IsFlagType}}"/>
                                    <TextBox Visibility="{Binding Type, Converter={StaticResource IsFlagType}}"
                                             Text="{Binding BitIndex, UpdateSourceTrigger=LostFocus}"
                                             IsReadOnly="{Binding IsInherited}"
                                             Margin="0 0 0 8"/>

                                    <!-- Description -->
                                    <Label Content="DESCRIPTION"/>
                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             Height="80" VerticalScrollBarVisibility="Auto"
                                             IsReadOnly="{Binding IsInherited}"
                                             Margin="0 0 0 8"/>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
