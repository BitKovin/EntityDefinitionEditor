<Window x:Class="EntityEditor.InheritPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Parent Entity" Height="320" Width="320"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#D4D4D4"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Choose a parent entity to inherit from:"
                   Foreground="#9CDCFE" Margin="0 0 0 8"/>

        <ListBox x:Name="listBox" Grid.Row="1"
                 Background="#252526" Foreground="#D4D4D4"
                 BorderBrush="#3F3F46" BorderThickness="1"
                 MouseDoubleClick="ListBox_MouseDoubleClick"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0">
            <Button Content="OK" Width="75" Margin="0 0 8 0" Click="OkClick"
                    Background="#007ACC" Foreground="White" BorderThickness="0" Padding="4"/>
            <Button Content="Cancel" Width="75" Click="CancelClick"
                    Background="#3F3F46" Foreground="#D4D4D4" BorderThickness="0" Padding="4"/>
        </StackPanel>
    </Grid>
</Window>
